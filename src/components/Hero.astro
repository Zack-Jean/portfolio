---
---

<section class="hero">
  <div class="eyebrow">
    <span class="eyebrow-line"></span>
    Technical Delivery Manager · AI Enablement
  </div>

  <h1>
    I build systems<br />
    that <em>actually</em><br />
    work.
  </h1>

  <p class="subheadline">
    Automation engineer and ops leader specializing in workflow design, AI
    integration, and the kind of tooling that eliminates the stuff nobody
    should be doing manually.
  </p>

  <div class="cta-row">
    <a href="#work" class="btn-primary">View my work</a>
    <a href="#contact" class="btn-ghost">Get in touch</a>
  </div>
</section>

<style>
  .hero {
    margin-bottom: 4rem;
  }

  .eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-accent);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .eyebrow-line {
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(42px, 8vw, 60px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -2px;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  h1 em {
    font-style: normal;
    color: var(--color-accent);
  }

  .subheadline {
    font-size: 17px;
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-muted);
    max-width: 520px;
    margin-bottom: 2.25rem;
  }

  .cta-row {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    padding: 11px 24px;
    background: var(--color-accent);
    color: #fff;
    border-radius: 6px;
    transition: opacity 0.15s;
  }

  .btn-primary:hover {
    opacity: 0.88;
  }

  .btn-ghost {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    padding: 11px 24px;
    background: transparent;
    color: var(--color-muted);
    border: 0.5px solid var(--color-border);
    border-radius: 6px;
    transition: border-color 0.15s, color 0.15s;
  }

  .btn-ghost:hover {
    border-color: #aaa;
    color: var(--color-text);
  }
</style>
