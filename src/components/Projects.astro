---
import { projects } from "../data/projects";

const featured = projects.find((p) => p.featured);
const rest = projects.filter((p) => !p.featured);
---

<div class="projects-section" id="work">
  <div class="section-label">
    selected work<span class="label-line"></span>
  </div>

  <div class="projects-grid">
    {featured && (
      <a href={`/work/${featured.slug}`} class="card card-featured">
        <div class="card-inner">
          <div class="card-header">
            <div class="card-icon">
              <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="2" y="2" width="5" height="5" rx="1" fill="#534AB7"/>
                <rect x="9" y="2" width="5" height="5" rx="1" fill="#AFA9EC"/>
                <rect x="2" y="9" width="5" height="5" rx="1" fill="#AFA9EC"/>
                <rect x="9" y="9" width="5" height="5" rx="1" fill="#534AB7"/>
              </svg>
            </div>
            <span class="featured-badge">Featured</span>
          </div>
          <h3>{featured.title}</h3>
          <p>{featured.description}</p>
          <div class="card-tags">
            {featured.tags.map((tag) => (
              <span class="card-tag">{tag}</span>
            ))}
          </div>
        </div>
      </a>
    )}

    {rest.map((project) => (
      <a href={`/work/${project.slug}`} class="card">
        <div class="card-icon">
          <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 13V7M6 13V4M9 13V9M12 13V5" stroke="#534AB7" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3>{project.title}</h3>
        <p>{project.description}</p>
        <div class="card-tags">
          {project.tags.map((tag) => (
            <span class="card-tag">{tag}</span>
          ))}
        </div>
      </a>
    ))}
  </div>
</div>

<style>
  .projects-section {
    margin-bottom: 4rem;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-muted);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .label-line {
    flex: 1;
    height: 0.5px;
    background: var(--color-border);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .card {
    display: block;
    background: #fff;
    border: 0.5px solid var(--color-border);
    border-radius: 10px;
    padding: 1.25rem;
    transition: border-color 0.15s;
    text-decoration: none;
    color: inherit;
  }

  .card:hover {
    border-color: #bbb;
  }

  .card-featured {
    grid-column: span 2;
    border-color: var(--color-accent-mid);
  }

  .card-featured:hover {
    border-color: var(--color-accent);
  }

  .card-inner {
    display: flex;
    flex-direction: column;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 12px;
  }

  .card-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--color-accent-light);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
    flex-shrink: 0;
  }

  .card-icon svg {
    width: 16px;
    height: 16px;
  }

  .card-featured .card-icon {
    margin-bottom: 0;
  }

  .featured-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    color: #3C3489;
    background: var(--color-accent-light);
    border: 0.5px solid var(--color-accent-mid);
    padding: 4px 10px;
    border-radius: 4px;
  }

  h3 {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--color-text);
    line-height: 1.3;
  }

  p {
    font-size: 13px;
    line-height: 1.65;
    color: var(--color-muted);
    margin-bottom: 14px;
    flex: 1;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .card-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 3px 8px;
    border-radius: 3px;
    background: var(--color-tag-bg);
    color: var(--color-muted);
  }

  @media (max-width: 560px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .card-featured {
      grid-column: span 1;
    }
  }
</style>