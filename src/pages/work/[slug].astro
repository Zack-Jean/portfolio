---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
  }));
}

const { slug } = Astro.params;
const project = projects.find((p) => p.slug === slug);

if (!project) return Astro.redirect("/");

// Extended content per project
const content: Record<string, {
  problem: string;
  solution: string;
  impact: string;
  details: string[];
}> = {
  scorecard: {
    problem: "QA reviews were manual, inconsistent, and time-consuming — reviewers spent hours pulling data from multiple disconnected systems with no single source of truth.",
    solution: "Built a fully automated scorecard system that integrates Zoho Desk (ticket volume, CSAT, escalations), Toggl Track (time-on-task), and internal QA logs through REST API connections — all orchestrated in Python. Each specialist's data is pulled, normalized, and scored against a weighted rubric that reflects actual business priorities: quality over volume, resolution over escalation. Results are written automatically to a Google Sheet dashboard that refreshes daily, giving reviewers a live, always-current view of team performance without touching a single export. The scoring model was designed to surface coaching signals, not just pass/fail grades — weighting dimensions like first-contact resolution and CSAT consistency higher than raw ticket count.",
    impact: "QA review time dropped by roughly 80%, freeing reviewers to spend time on coaching conversations rather than data assembly. Performance discussions shifted from subjective impressions to specific, data-backed observations. Patterns that were previously invisible — like a specialist who scored high on volume but consistently underperformed on escalation rate — became immediately actionable. The system also created a historical record of performance over time, enabling trend analysis that simply wasn't possible before.",
    details: ["Python", "Zoho Desk REST API", "Toggl Track API", "Google Sheets API", "Weighted scoring rubric", "Automated daily refresh"],
  },
  "toggl-sheets": {
    problem: "Kijiji client reporting required manually compiling Toggl time data across two separate workspaces — a tedious weekly process prone to errors and inconsistency.",
    solution: "Built a Google Apps Script pipeline that authenticates against both Toggl workspaces simultaneously, pulls billable hours by project and team member, and applies normalization logic to reconcile inconsistent region labels across workspaces. The script handles the full reporting surface: filtering for billable-only entries, mapping projects to the correct team and region via a declarative override system, and writing everything to a formatted Google Sheet. A monthly export routine pushes the finalized data to an external shared sheet accessible to the client. The entire pipeline runs automatically every morning via a time-based trigger — no one has to remember to run it.",
    impact: "Eliminated approximately three hours of weekly manual work and removed a recurring source of reporting errors caused by human inconsistency. The client now receives data that's fresher, more accurate, and formatted consistently every time. Internally, the team gained confidence that what they're reporting matches what was actually tracked — something that was genuinely uncertain before. The monthly export also simplified client handoffs, replacing an ad-hoc email attachment process with a shared sheet that's always up to date.",
    details: ["Google Apps Script", "Toggl Track API", "Multi-workspace auth", "Billable hour filters", "Region normalization", "Automated daily trigger", "Monthly export"],
  },
  "ops-revenue": {
    problem: "Leadership needed regular visibility into ops revenue metrics, but the existing process required manual data pulls and a formatted email built from scratch each time.",
    solution: "Built an Apps Script report (sendOpsRevenueReport) that queries Monday.com for live ops data using the GraphQL API, then transforms and formats it as an inline HTML email with full Feedonomics brand styling — Indigo/Violet color hierarchy, DM Sans typography, and consistent table layouts. The script applies row-capping logic to ensure the rendered email stays under Gmail's 102KB HTML rendering limit, preventing clipping in recipients' inboxes. Once formatted, the report sends automatically on a set schedule. Because the data is pulled live at send time, every email reflects current state — not a snapshot from whenever someone last remembered to check.",
    impact: "Ops revenue visibility went from ad-hoc and inconsistent to automated and reliable. Leadership receives a polished, on-brand report on a predictable cadence without any manual effort from the ops team. The inline HTML approach means the report renders cleanly in Gmail without attachment friction or formatting drift. Perhaps more importantly, the team reclaimed the time and mental overhead that had been quietly absorbed by this recurring task — freeing it for higher-leverage work.",
    details: ["Google Apps Script", "Monday.com API", "Gmail API", "Inline HTML email", "Row-cap logic", "Scheduled delivery"],
  },
  "ai-enablement": {
    problem: "Claude was available to the team but adoption was low and inconsistent — most staff didn't know how to prompt effectively or where it fit into their workflow.",
    solution: "Designed and delivered a three-session Claude AI Enablement Program built specifically for the Global Services team — not a generic AI overview, but a practical curriculum mapped to the actual work the team does. Session one covered claude.ai fundamentals and basic prompt structure. Session two went deeper on prompt engineering: context-setting, role assignment, iteration, and output formatting. Session three focused on workflow integration — identifying where AI adds the most leverage in a support and operations context, and building habits that stick. Each session included live demos, team exercises, and real use cases drawn from existing workflows. A curated prompt library was built alongside the curriculum and made immediately usable. Usage tracking was set up to measure adoption over time.",
    impact: "Claude adoption increased measurably across the team within weeks of the first session. Staff who previously used it occasionally — or not at all — moved to integrated daily use. The shift wasn't just in frequency but in sophistication: prompts became more intentional, outputs more useful, and the team developed a shared vocabulary around AI that made collaboration easier. The program is now being expanded to additional teams, and the curriculum is being adapted as a repeatable internal training asset.",
    details: ["Claude / Anthropic", "Prompt engineering", "3-session curriculum", "Prompt library", "Usage analytics", "Training materials"],
  },
  "monday-board": {
    problem: "Monday.com's native reporting didn't surface the cross-board operational metrics leadership needed, and manual exports were slow and stale.",
    solution: "Built a Google Apps Script integration against Monday.com's GraphQL API using a declarative FIELD_CONFIG pattern — making it easy to add, remove, or reconfigure tracked fields without touching core logic. To handle Monday.com's API rate limits at scale, the integration uses a parallel fetchAll approach with batch chunking: items are processed in groups of 10 with a 1500ms delay between batches, eliminating quota errors that had plagued earlier attempts. The dashboard supports both Zoho Desk and Salesforce link patterns natively, surfacing the correct CRM link based on account type without any manual tagging. Everything renders in a unified ops view that refreshes on demand.",
    impact: "A manual weekly reporting process was replaced by a real-time dashboard that anyone on the ops team can open and trust. The batch architecture solved a scaling problem that made previous approaches unreliable — the system now handles full board loads without hitting API limits. The declarative config pattern also made the integration significantly easier to maintain and extend; adding a new field to the dashboard takes minutes rather than requiring a code dive. Leadership gained operational visibility that simply didn't exist before.",
    details: ["Google Apps Script", "Monday.com GraphQL API", "Batch fetching", "Declarative field config", "Zoho + Salesforce link support"],
  },
  "make-sop": {
    problem: "Make.com automations were being built inconsistently across the team — no naming conventions, logging standards, or deployment process — creating a growing maintenance and security risk.",
    solution: "Wrote a comprehensive Make.com governance SOP from the ground up, covering every layer of the automation lifecycle: naming conventions, scenario architecture patterns, security requirements, a formal TESTING → LIVE deployment process, and a 12-field logging schema that writes structured run data to a centralized MakeScenarioRunLogs sheet. Slack alerting was integrated into the standard so that failures surface in #global-services-ai-champions in real time rather than silently. The SOP was written to be immediately actionable — not a policy document that sits in a drawer, but a hands-on reference that engineers consult while building. It includes annotated examples, field-by-field schema documentation, and a pre-deployment checklist.",
    impact: "New scenarios are built to spec from day one, reducing the debugging time that previously came from inconsistent builds. The centralized logging schema created operational visibility that didn't exist before — run history, error rates, and execution timing are now queryable across all scenarios. The TESTING → LIVE gate caught multiple issues during the rollout period that would have otherwise hit production. Audit risk dropped significantly as the team moved from a 'figure it out as you go' approach to a documented, repeatable practice.",
    details: ["Make.com", "Governance framework", "12-field logging schema", "Slack alerting", "TESTING/LIVE environments", "Security architecture"],
  },
};

const detail = content[slug!] ?? {
  problem: "Coming soon.",
  solution: "Coming soon.",
  impact: "Coming soon.",
  details: project.tags,
};
---

<Layout
  title={`${project.title} — Zack Jean`}
  description={project.description}
  ogTitle={project.title}
  ogSub="Case Study · zackjean.com"
>
  <main>
    <Nav />

    <article class="case-study">
      <a href="/#work" class="back-link">← Back to work</a>

      <div class="eyebrow">
        <span class="eyebrow-line"></span>
        Case Study
      </div>

      <h1>{project.title}</h1>
      <p class="summary">{project.description}</p>

      <div class="tags">
        {project.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>

      <div class="sections">
        <div class="section">
          <div class="section-label">The problem</div>
          <p>{detail.problem}</p>
        </div>

        <div class="section">
          <div class="section-label">The solution</div>
          <p>{detail.solution}</p>
        </div>

        <div class="section">
          <div class="section-label">The impact</div>
          <p>{detail.impact}</p>
        </div>

        <div class="section">
          <div class="section-label">Tech & tools</div>
          <div class="detail-tags">
            {detail.details.map((d) => (
              <span class="detail-tag">{d}</span>
            ))}
          </div>
        </div>
      </div>
    </article>
  </main>
</Layout>

<style>
  .case-study {
    max-width: 620px;
    padding-bottom: 4rem;
  }

  .back-link {
    display: inline-block;
    font-size: 13px;
    font-family: var(--font-mono);
    color: var(--color-muted);
    margin-bottom: 2rem;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-accent);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .eyebrow-line {
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--color-accent);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 700;
    letter-spacing: -1px;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .summary {
    font-size: 16px;
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 3rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 5px 12px;
    border-radius: 4px;
    background: var(--color-accent-light);
    color: #3C3489;
    border: 0.5px solid var(--color-accent-mid);
  }

  .sections {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .section {
    border-left: 2px solid var(--color-accent-mid);
    padding-left: 1.25rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .section p {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-muted);
  }

  .detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .detail-tag {
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 5px 12px;
    border-radius: 4px;
    background: var(--color-tag-bg);
    color: var(--color-muted);
    border: 0.5px solid var(--color-border);
  }
</style>