---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";

const experience = [
  {
    role: "Senior Manager, Global Technical Operations",
    company: "Feedonomics / BigCommerce",
    period: "2021 — Present",
    note: "Promoted from Manager, Global Technical Operations",
    description:
      "Direct global SaaS operations strategy, automation architecture, and reporting infrastructure across international teams. Own multi-year technical operations roadmap, prioritizing automation investment, capacity planning, and enterprise scalability.",
    highlights: [
      "Delivered $3.7M+ in cost savings and 60,000+ annual labor hours eliminated through automation strategy",
      "Designed and scaled automation frameworks (Python/JavaScript) eliminating 7,500+ annual labor hours",
      "Architected BI infrastructure enabling real-time operational visibility, reducing reporting cycles by 30%",
      "Redesigned global ticket routing logic, decreasing SLA violations by 70%",
      "Lead and develop a global team of 18 technical specialists across NA & EMEA",
      "Present automation strategy and roadmap priorities to executive leadership on a recurring basis",
      "Serve as senior liaison between product, engineering, and operations for enterprise client alignment",
    ],
  },
  {
    role: "RPA Product Manager & Global Operations Agile Lead",
    company: "Deckers Brands",
    period: "2017 — 2021",
    note: "",
    description:
      "Led enterprise automation strategy and agile product delivery across global systems.",
    highlights: [
      "Built and scaled enterprise RPA program from inception to 45,000+ annual hours saved",
      "Delivered $750K+ in direct cost savings through RPA program",
      "Designed enterprise risk mitigation platform generating $3M+ net positive impact in first year",
      "Eliminated $100K annual vendor spend via internal HR automation platform",
      "Directed cross-functional agile teams delivering 987 production releases across enterprise OMS platform",
      "Established enterprise automation governance framework and Center of Excellence",
      "Led global system optimization initiatives across NA, EMEA, and APAC operations",
    ],
  },
];

const skills = {
  "Automation & Engineering": ["Python", "JavaScript", "RPA (UiPath)", "REST APIs", "Make.com", "Zapier"],
  "Data & Analytics": ["Tableau", "SQL", "PowerBI", "LookerStudio", "Google Sheets", "Oracle BIEE/BAM"],
  "Platforms & Systems": ["Salesforce", "HubSpot", "ServiceNow", "Jira", "Confluence", "Oracle EBS", "Zoho Desk"],
  "AI & Enablement": ["Claude / Anthropic", "Prompt Engineering", "AI Workflow Design", "L&D Curriculum"],
  "Methodologies": ["Agile/Scrum", "Systems Architecture", "Process Optimization", "Change Management"],
  "Leadership": ["Global Team Leadership", "Strategic Planning", "Budget Ownership", "Cross-Functional Execution"],
};
---

<Layout
  title="Resume — Zack Jean"
  description="Resume of Zack Jean — Technical Operations Leader specializing in SaaS automation, scalable systems architecture, and high-performing global teams."
  ogTitle="Zack Jean — Resume"
  ogSub="Technical Operations Leader · AI Enablement"
>
  <main>
    <Nav />

    <div class="resume-header">
      <div class="eyebrow">
        <span class="eyebrow-line"></span>
        Resume
      </div>
      <h1>Zack Jean</h1>
      <p class="tagline">Technical Operations Leader · Automation Architect · AI Enablement</p>
      <p class="exec-summary">
        Specializing in SaaS automation, scalable systems architecture, and building high-performing global teams. Delivered $3.7M+ in cost savings and 60,000+ annual labor hours through automation strategy and cross-functional product partnership.
      </p>
      <div class="header-links">
        <a href="mailto:zack.jean@gmail.com">zack.jean@gmail.com</a>
        <span class="dot">·</span>
        <a href="https://linkedin.com/in/zackjean" target="_blank" rel="noopener">LinkedIn</a>
        <span class="dot">·</span>
        <a href="https://github.com/Zack-Jean" target="_blank" rel="noopener">GitHub</a>
        <span class="dot">·</span>
        <span>Clarkdale, AZ</span>
      </div>
    </div>

    <div class="resume-body">
      <div class="resume-main">
        <div class="section-label">Experience<span class="label-line"></span></div>

        <div class="timeline">
          {experience.map((job) => (
            <div class="timeline-item">
              <div class="timeline-dot"></div>
              <div class="timeline-content">
                <div class="job-header">
                  <div>
                    <div class="job-role">{job.role}</div>
                    <div class="job-company">{job.company}</div>
                    {job.note && <div class="job-note">{job.note}</div>}
                  </div>
                  <div class="job-period">{job.period}</div>
                </div>
                <p class="job-desc">{job.description}</p>
                <ul class="job-highlights">
                  {job.highlights.map((h) => (
                    <li>{h}</li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="resume-sidebar">
        <div class="section-label">Skills<span class="label-line"></span></div>
        {Object.entries(skills).map(([category, items]) => (
          <div class="skill-group">
            <div class="skill-category">{category}</div>
            <div class="skill-tags">
              {items.map((skill) => (
                <span class="skill-tag">{skill}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>

<style>
  .resume-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 0.5px solid var(--color-border);
  }

  .eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-accent);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .eyebrow-line {
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--color-accent);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 6vw, 52px);
    font-weight: 700;
    letter-spacing: -1.5px;
    line-height: 1.05;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 15px;
    font-weight: 300;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  .exec-summary {
    font-size: 14px;
    line-height: 1.75;
    color: var(--color-muted);
    max-width: 620px;
    margin-bottom: 1rem;
    font-weight: 300;
  }

  .header-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    font-size: 13px;
    color: var(--color-muted);
  }

  .header-links a {
    color: var(--color-accent);
  }

  .header-links a:hover {
    text-decoration: underline;
  }

  .dot { color: var(--color-border); }

  .resume-body {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 3rem;
    align-items: start;
    padding-bottom: 4rem;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-muted);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .label-line {
    flex: 1;
    height: 0.5px;
    background: var(--color-border);
  }

  .timeline {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 8px;
    bottom: 0;
    width: 1px;
    background: var(--color-border);
  }

  .timeline-item {
    display: flex;
    gap: 1.25rem;
    padding-bottom: 2.5rem;
    position: relative;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-dot {
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 2px solid #fff;
    flex-shrink: 0;
    margin-top: 4px;
    position: relative;
    z-index: 1;
  }

  .timeline-content {
    flex: 1;
  }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .job-role {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }

  .job-company {
    font-size: 13px;
    color: var(--color-accent);
    margin-top: 2px;
  }

  .job-note {
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--color-muted);
    margin-top: 3px;
  }

  .job-period {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-muted);
    white-space: nowrap;
    padding-top: 3px;
  }

  .job-desc {
    font-size: 14px;
    line-height: 1.75;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  .job-highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .job-highlights li {
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-muted);
    padding-left: 1rem;
    position: relative;
  }

  .job-highlights li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent-mid);
    font-size: 11px;
    top: 2px;
  }

  .skill-group {
    margin-bottom: 1.25rem;
  }

  .skill-category {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-muted);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .skill-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 4px;
    background: var(--color-tag-bg);
    color: var(--color-muted);
    border: 0.5px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .resume-body {
      grid-template-columns: 1fr;
    }
  }
</style>